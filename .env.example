# Spend Trend Skill — Environment Variables
  # Copy this file to .env and fill in your values. Never commit .env to git.

  # ── CloudZero API Keys ────────────────────────────────────────────────────────
  # One key per client. Add as many as you need.
  # Key name must match the env_key value in spend_trend_runner.py CLIENTS list.

  CLIENT_A_API_KEY=paste_your_cloudzero_api_key_here
  CLIENT_B_API_KEY=paste_your_cloudzero_api_key_here

  # ── Optional: Slack ───────────────────────────────────────────────────────────
  # Get from: Slack > Your App > Incoming Webhooks
  # Leave blank to skip Slack posting.

  SLACK_WEBHOOK_URL=

  # ── Optional: Email (Gmail) ───────────────────────────────────────────────────
  GMAIL_USER=
  GMAIL_APP_PASSWORD=paste_your_gmail_app_password_here
  EMAIL_RECIPIENT=

  # ── Optional: Path overrides ──────────────────────────────────────────────────
  # CLIENTS_DIR=/path/to/your/clients
  # OVERVIEW_DIR=/path/to/spend-trend-overview
  # ENV_FILE=/path/to/.env

  ---


